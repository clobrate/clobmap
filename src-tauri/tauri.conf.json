{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "clobmap",
  "version": "0.1.0",
  "identifier": "com.clobmap.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "clobmap",
        "width": 1100,
        "height": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "shortDescription": "Minimalistic mind-mapping with YAML toggle",
    "longDescription": "clobmap is a minimalistic mind-mapping app where the YAML view and the visual mind-map view are equally first-class. Edit either; the other follows.",
    "category": "Productivity",
    "copyright": "© 2026 clobmap contributors",
    "fileAssociations": [
      {
        "name": "Clobmap mind map",
        "description": "Clobmap mind-map document",
        "ext": ["clobmap.yaml"],
        "role": "Editor",
        "mimeType": "application/x-clobmap-yaml"
      }
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "frameworks": [],
      "exceptionDomain": ""
    },
    "windows": {
      "wix": {
        "language": ["en-US"]
      },
      "nsis": {
        "installMode": "perMachine"
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/clobrate/clobmap/releases/latest/download/latest.json"],
      "pubkey": "REPLACE_WITH_PUBKEY_FROM_TAURI_SIGNER_GENERATE"
    }
  }
}
